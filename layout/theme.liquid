<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>

<meta charset="utf-8">

<meta name="viewport" content="width=device-width,initial-scale=1">

<title>
{{ page_title }}
{% if current_tags %}
– {{ current_tags | join: ', ' }}
{% endif %}
{% if current_page != 1 %}
– Page {{ current_page }}
{% endif %}
</title>

{{ content_for_header }}

{{ 'base.css' | asset_url | stylesheet_tag }}
{{ 'theme.css' | asset_url | stylesheet_tag }}

</head>

<body>

{% section 'announcement-bar' %}

{% section 'header' %}

<main id="MainContent">
{{ content_for_layout }}
</main>

{% section 'footer' %}

{{ 'theme.js' | asset_url | script_tag }}

</body>
</html>
